# === CARRIER TOGGLE ===
# Set to "twilio" or "signalwire" to choose which carrier handles calls
VOICE_CARRIER=twilio

# === Twilio ===
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# === SignalWire (optional — only needed if VOICE_CARRIER=signalwire) ===
SIGNALWIRE_SPACE=your-space.signalwire.com
SIGNALWIRE_PROJECT_ID=your_signalwire_project_id
SIGNALWIRE_API_TOKEN=your_signalwire_api_token
SIGNALWIRE_PHONE_NUMBER=+1XXXXXXXXXX

# === Claude AI (for call analysis + daily summaries) ===
ANTHROPIC_API_KEY=your_anthropic_api_key

# === GoHighLevel ===
GHL_API_KEY=your_ghl_pit_token
GHL_LOCATION_ID=n778xwOps9t8Q34eRPfM

# === Dashboard Auth (Claude and the web dashboard use this to authenticate) ===
DIALER_API_KEY=your_dialer_api_key

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
